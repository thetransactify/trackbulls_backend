APP_NAME=TrackBulls API
APP_ENV=development
APP_PORT=8000
DEBUG=true
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_MIN_32_CHARS

DB_HOST=localhost
DB_PORT=5432
DB_NAME=trackbulls
DB_USER=trackbulls_user
DB_PASSWORD=CHANGE_THIS_PASSWORD
DATABASE_URL=postgresql://trackbulls_user:CHANGE_THIS_PASSWORD@localhost:5432/trackbulls

USE_SQLITE=false
SQLITE_PATH=./trackbulls_dev.db

REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=10

JWT_SECRET_KEY=CHANGE_THIS_TO_ANOTHER_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=http://localhost:8000/api/v1/broker/kite/callback

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_EMAIL_TO=

CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

DEFAULT_CAPITAL=100000
MAX_DAILY_LOSS_PCT=2.0
MAX_TRADE_RISK_PCT=1.0
DEFAULT_TARGET_PCT=2.0
DEFAULT_STOPLOSS_PCT=1.0
CONFIDENCE_THRESHOLD=65
PAPER_MODE=true
